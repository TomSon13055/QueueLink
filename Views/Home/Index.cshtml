@{
    ViewData["Title"] = "Trang chủ";
    Layout = "_Layout";
}

<!-- Hero -->
<section class="hero-section text-white text-center d-flex align-items-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h1 class="display-3 fw-bold mb-3">
                    <i class="bi bi-qr-code-scan"></i> QueueLink
                </h1>
                <p class="lead fs-3 mb-4">Lấy số online, tự do trải nghiệm trong lúc chờ</p>
                <p class="fs-5 text-white-50 mb-5">Quét QR, nhận số thứ tự và theo dõi hàng chờ realtime mà không cần tải app.</p>
                <a asp-controller="Queue" asp-action="Index" class="btn btn-light btn-lg px-4 py-3 fw-bold shadow me-2">
                    <i class="bi bi-search me-2"></i>Tìm hàng chờ
                </a>
                <a asp-controller="Queue" asp-action="Scan" class="btn btn-outline-light btn-lg px-4 py-3 fw-bold">
                    <i class="bi bi-qr-code-scan me-2"></i>Quét QR
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Features -->
<section class="py-5 bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Tại sao chọn QueueLink?</h2>
            <p class="text-muted">Trải nghiệm hàng chờ thông minh, không giới hạn</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4 feature-card">
                    <div class="card-body">
                        <i class="bi bi-phone text-primary fs-1 mb-3"></i>
                        <h5 class="fw-bold">Không cần tải app</h5>
                        <p class="text-muted">Chỉ cần quét mã QR bằng camera điện thoại là dùng ngay, không cần cài đặt.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4 feature-card">
                    <div class="card-body">
                        <i class="bi bi-lightning-charge text-warning fs-1 mb-3"></i>
                        <h5 class="fw-bold">Quét QR là dùng ngay</h5>
                        <p class="text-muted">Mở link, nhập thông tin, nhận số thứ tự chỉ trong vài giây.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4 feature-card">
                    <div class="card-body">
                        <i class="bi bi-broadcast text-success fs-1 mb-3"></i>
                        <h5 class="fw-bold">Theo dõi realtime</h5>
                        <p class="text-muted">Biết chính xác có bao nhiêu người phía trước và thời gian chờ ước tính.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4 feature-card">
                    <div class="card-body">
                        <i class="bi bi-people text-info fs-1 mb-3"></i>
                        <h5 class="fw-bold">Biết số người phía trước</h5>
                        <p class="text-muted">Tự do đi lại, shopping hoặc nghỉ ngơi trong khi chờ đến lượt.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4 feature-card">
                    <div class="card-body">
                        <i class="bi bi-clock-history text-secondary fs-1 mb-3"></i>
                        <h5 class="fw-bold">Ước tính thời gian chờ</h5>
                        <p class="text-muted">Hệ thống tự động tính ETA dựa trên thời gian phục vụ trung bình.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4 feature-card">
                    <div class="card-body">
                        <i class="bi bi-emoji-smile text-danger fs-1 mb-3"></i>
                        <h5 class="fw-bold">Giảm chen chúc</h5>
                        <p class="text-muted">Khách không cần xếp hàng tại sảnh, không còn cảnh đông đúc, chen chúc.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5 bg-primary text-white text-center">
    <div class="container">
        <h2 class="fw-bold mb-3">Bắt đầu ngay hôm nay</h2>
        <p class="mb-4 fs-5">Quét mã QR tại quầy hoặc tìm hàng chờ gần bạn</p>
        <a asp-controller="Queue" asp-action="Index" class="btn btn-light btn-lg px-5 py-3 fw-bold">
            <i class="bi bi-arrow-right-circle me-2"></i>Tìm hàng chờ
        </a>
    </div>
</section>
