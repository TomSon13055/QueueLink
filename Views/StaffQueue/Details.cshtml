@model QueueLink.ViewModels.StaffQueueDashboardViewModel
@{
    ViewData["Title"] = "Staff - " + Model.QueueServiceName;
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">
                <i class="bi bi-display me-2 text-primary"></i>@Model.QueueServiceName
            </h2>
            <p class="text-muted mb-0"><i class="bi bi-geo-alt me-1"></i>@Model.VenueName</p>
        </div>
        <div class="d-flex gap-2">
            <span class="badge @(Model.QueueStatus == QueueLink.Models.QueueStatus.Open ? "bg-success" : "bg-secondary") fs-6 px-3 py-2">
                @(Model.QueueStatus == QueueLink.Models.QueueStatus.Open ? "Open" : "Closed")
            </span>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Quay lại
            </a>
        </div>
    </div>

    <!-- Info cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center border-0 shadow-sm bg-primary text-white">
                <div class="card-body py-3">
                    <div class="small text-uppercase opacity-75">Đang chờ</div>
                    <div class="display-6 fw-bold" id="waitingCount">@Model.WaitingCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-0 shadow-sm bg-warning text-dark">
                <div class="card-body py-3">
                    <div class="small text-uppercase opacity-75">Đang gọi</div>
                    <div class="display-6 fw-bold" id="currentCall">@Model.CurrentCallingTicketCode</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-0 shadow-sm bg-info text-white">
                <div class="card-body py-3">
                    <div class="small text-uppercase opacity-75">Phục vụ TB</div>
                    <div class="display-6 fw-bold">@Model.AverageEstimatedWaitMinutes phút</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-0 shadow-sm bg-secondary text-white">
                <div class="card-body py-3">
                    <div class="small text-uppercase opacity-75">Trạng thái</div>
                    <div class="fs-5 fw-bold">@(Model.QueueStatus == QueueLink.Models.QueueStatus.Open ? "Mở cửa" : "Đóng cửa")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Call Next -->
    @if (Model.QueueStatus == QueueLink.Models.QueueStatus.Open)
    {
        <form asp-action="CallNext" method="post" class="mb-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="queueServiceId" value="@Model.QueueServiceId" />
            <button type="submit" class="btn btn-success btn-lg px-5 py-3 fw-bold shadow">
                <i class="bi bi-megaphone-fill me-2"></i>Gọi số tiếp theo
            </button>
        </form>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info">@TempData["Info"]</div>
    }

    <!-- Ticket Table -->
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i>Danh sách ticket hôm nay</h5>
            <button class="btn btn-outline-primary btn-sm" onclick="location.reload()">
                <i class="bi bi-arrow-clockwise me-1"></i>Làm mới
            </button>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Số</th>
                        <th>Tên khách</th>
                        <th>Điện thoại</th>
                        <th>Số khách</th>
                        <th>Trạng thái</th>
                        <th>Chờ ước tính</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Tickets)
                    {
                        <tr class="align-middle @(t.Status == QueueLink.Models.TicketStatus.Called ? "table-warning" : t.Status == QueueLink.Models.TicketStatus.Serving ? "table-info" : "")">
                            <td>
                                <span class="fw-bold fs-5 @(t.Status == QueueLink.Models.TicketStatus.Waiting ? "text-primary" : "")">@t.TicketCode</span>
                            </td>
                            <td>@t.CustomerName</td>
                            <td>@t.CustomerPhone</td>
                            <td>@t.PartySize</td>
                            <td>
                                <span class="badge @(GetTicketBadgeClass(t.Status))">@t.StatusText</span>
                            </td>
                            <td>@(t.EstimatedWaitMinutes > 0 ? t.EstimatedWaitMinutes + " phút" : "-")</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    @if (t.Status == QueueLink.Models.TicketStatus.Called)
                                    {
                                        <form asp-action="MarkServing" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ticketId" value="@t.TicketId" />
                                            <button type="submit" class="btn btn-info" title="Mark Serving">
                                                <i class="bi bi-person-check"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (t.Status == QueueLink.Models.TicketStatus.Serving)
                                    {
                                        <form asp-action="Complete" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ticketId" value="@t.TicketId" />
                                            <button type="submit" class="btn btn-success" title="Complete">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (t.Status == QueueLink.Models.TicketStatus.Waiting)
                                    {
                                        <form asp-action="MarkServing" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ticketId" value="@t.TicketId" />
                                            <button type="submit" class="btn btn-info btn-sm" title="Gọi & Serving">
                                                <i class="bi bi-person-check"></i>
                                            </button>
                                        </form>
                                    }
                                    <form asp-action="NoShow" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ticketId" value="@t.TicketId" />
                                        <button type="submit" class="btn btn-secondary btn-sm" title="No Show">
                                            <i class="bi bi-person-x"></i>
                                        </button>
                                    </form>
                                    @if (t.Status == QueueLink.Models.TicketStatus.Waiting || t.Status == QueueLink.Models.TicketStatus.Called)
                                    {
                                        <form asp-action="Cancel" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ticketId" value="@t.TicketId" />
                                            <button type="submit" class="btn btn-danger btn-sm" title="Cancel">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Tickets.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                Không có ticket nào hôm nay
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    string GetTicketBadgeClass(QueueLink.Models.TicketStatus s) => s switch
    {
        QueueLink.Models.TicketStatus.Waiting => "bg-primary",
        QueueLink.Models.TicketStatus.Called => "bg-warning text-dark",
        QueueLink.Models.TicketStatus.Serving => "bg-info",
        QueueLink.Models.TicketStatus.Completed => "bg-success",
        QueueLink.Models.TicketStatus.NoShow => "bg-secondary",
        QueueLink.Models.TicketStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}

@section Scripts {
    <script src="~/js/queue-realtime.js"></script>
    <script>
        window.queueLinkConfig = {
            queueServiceId: @Model.QueueServiceId,
            isStaff: true
        };
    </script>
}
