@model QueueLink.ViewModels.QueueServiceFormViewModel
@{
    ViewData["Title"] = "Sửa hàng chờ";
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-pencil me-2"></i>Sửa hàng chờ</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-3">
                            <label asp-for="VenueId" class="form-label fw-semibold"></label>
                            <select asp-for="VenueId" class="form-select form-select-lg" asp-items="ViewBag.Venues"></select>
                            <span asp-validation-for="VenueId" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Prefix" class="form-label fw-semibold"></label>
                                <input asp-for="Prefix" class="form-control" maxlength="5" />
                                <span asp-validation-for="Prefix" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="AverageServiceMinutes" class="form-label fw-semibold"></label>
                                <input asp-for="AverageServiceMinutes" class="form-control" type="number" min="1" max="240" />
                                <span asp-validation-for="AverageServiceMinutes" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="QueueStatus" class="form-label fw-semibold"></label>
                            <select asp-for="QueueStatus" class="form-select">
                                <option value="0">Open</option>
                                <option value="1">Paused</option>
                                <option value="2">Closed</option>
                            </select>
                        </div>
                        <div class="form-check mb-4">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold"></label>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Lưu</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
