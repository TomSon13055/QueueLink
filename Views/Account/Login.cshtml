@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập</h4>
                </div>
                <div class="card-body p-4">
                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger">
                            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <p class="mb-0">@err.ErrorMessage</p>
                            }
                        </div>
                    }

                    <form asp-controller="Account" asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input name="email" type="email" class="form-control form-control-lg" placeholder="admin@queuelink.com" required autofocus />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mật khẩu</label>
                            <input name="password" type="password" class="form-control form-control-lg" placeholder="••••••" required />
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                        </button>
                    </form>

                    <hr class="my-4" />
                    <p class="text-muted small text-center mb-0">
                        <strong>Demo accounts:</strong><br />
                        Admin &rarr; admin@queuelink.com / Admin@123<br />
                        Staff &rarr; staff@queuelink.com / Staff@123
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
