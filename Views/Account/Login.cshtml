@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập</h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }
                    @if (TempData["Info"] != null)
                    {
                        <div class="alert alert-info">@TempData["Info"]</div>
                    }

                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger">
                            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <p class="mb-0">@err.ErrorMessage</p>
                            }
                        </div>
                    }

                    @* ── Magic Link ──────────────────────────────────── *@
                    <form asp-controller="Account" asp-action="MagicLinkLogin" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input name="Email" type="email" class="form-control form-control-lg"
                                   placeholder="your@email.com" required autofocus />
                        </div>
                        <button type="submit" class="btn btn-outline-primary btn-lg w-100 mb-3">
                            <i class="bi bi-envelope-at me-2"></i>Gửi liên kết đăng nhập (Magic Link)
                        </button>
                    </form>

                    <div class="text-center text-muted small my-2">hoặc đăng nhập bằng mật khẩu</div>

                    @* ── Password Login ──────────────────────────────── *@
                    <form asp-controller="Account" asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input name="email" type="email" class="form-control form-control-lg"
                                   placeholder="your@email.com" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mật khẩu</label>
                            <input name="password" type="password" class="form-control form-control-lg"
                                   placeholder="••••••" required />
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập bằng mật khẩu
                        </button>
                    </form>

                    <hr class="my-4" />
                    <p class="text-center small mb-0">
                        Chưa có tài khoản?
                        <a asp-action="Register" class="fw-semibold">Đăng ký ngay</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
