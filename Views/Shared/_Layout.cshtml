@using Microsoft.AspNetCore.Identity
@inject SignInManager<QueueLink.Models.ApplicationUser> SignInManager
@inject UserManager<QueueLink.Models.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="vi" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QueueLink</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-qr-code-scan me-1"></i>QueueLink
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto align-items-center gap-1">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Queue" asp-action="Index"><i class="bi bi-search me-1"></i>Tìm hàng chờ</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Queue" asp-action="Scan"><i class="bi bi-qr-code-scan me-1"></i>Quét QR</a></li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Venue" asp-action="Index"><i class="bi bi-geo-alt me-1"></i>Địa điểm</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="QueueService" asp-action="Index"><i class="bi bi-list-ul me-1"></i>Hàng chờ</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Owner" asp-action="SelectVenue"><i class="bi bi-shop me-1"></i>Quản lý quán</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Staff" asp-action="FloorPlan"><i class="bi bi-grid-3x3-gap me-1"></i>Sơ đồ bàn</a></li>
                        }
                        else if (User.IsInRole("Staff"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Staff" asp-action="FloorPlan"><i class="bi bi-grid-3x3-gap me-1"></i>Sơ đồ bàn</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Staff" asp-action="Reservations"><i class="bi bi-calendar-event me-1"></i>Đặt trước</a></li>
                        }
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="nav-link btn btn-link text-light p-0"><i class="bi bi-box-arrow-right me-1"></i>Đăng xuất</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Queue" asp-action="Index"><i class="bi bi-search me-1"></i>Tìm hàng chờ</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Queue" asp-action="Scan"><i class="bi bi-qr-code-scan me-1"></i>Quét QR</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About"><i class="bi bi-info-circle me-1"></i>Giới thiệu</a></li>
                        <li class="nav-item d-lg-none"><a class="nav-link" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-1"></i>Đăng ký</a></li>
                    }
                </ul>
            </div>
            @if (!SignInManager.IsSignedIn(User))
            {
                <a class="btn btn-light text-primary btn-sm ms-2 ms-lg-3 d-none d-lg-inline-flex align-items-center gap-1" asp-controller="Account" asp-action="Register">
                    <i class="bi bi-person-plus"></i><span>Đăng ký</span>
                </a>
                <a class="btn btn-warning text-dark fw-semibold btn-sm ms-2 d-inline-flex align-items-center gap-1" asp-controller="Account" asp-action="Login">
                    <i class="bi bi-box-arrow-in-right"></i><span>Đăng nhập</span>
                </a>
            }
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="bg-light py-4 mt-5 border-top">
        <div class="container text-center text-muted small">
            <p class="mb-1 fw-semibold">QueueLink &mdash; Lấy số online, tự do trải nghiệm</p>
            <p class="mb-0">&copy; @DateTime.Now.Year QueueLink. Thông báo qua email cho khách hàng.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
