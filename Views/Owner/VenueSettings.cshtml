@model QueueLink.ViewModels.VenueFormViewModel
@{
    ViewData["Title"] = "Cài đặt quán — " + ViewBag.VenueName;
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-controller="Owner" asp-action="Dashboard" asp-route-venueId="@Model.Id" class="btn btn-link text-decoration-none p-0 mb-2">
                <i class="bi bi-arrow-left"></i> Quay lại Dashboard
            </a>
            <h4 class="fw-bold mb-0"><i class="bi bi-gear me-2 text-primary"></i>Cài đặt quán</h4>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-shop me-2"></i>@ViewBag.VenueName</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-controller="Owner" asp-action="VenueSettings">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Address" class="form-label fw-semibold"></label>
                                <input asp-for="Address" class="form-control" />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label fw-semibold"></label>
                                <input asp-for="Phone" class="form-control" />
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Slug" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text">queuelink.com/</span>
                                    <input asp-for="Slug" class="form-control" placeholder="dookki-vincom" />
                                </div>
                                <small class="text-muted">URL công khai của quán</small>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="OpenTime" class="form-label fw-semibold"></label>
                                <input asp-for="OpenTime" class="form-control" type="time" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="CloseTime" class="form-label fw-semibold"></label>
                                <input asp-for="CloseTime" class="form-control" type="time" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="LogoUrl" class="form-label fw-semibold"></label>
                            <input asp-for="LogoUrl" class="form-control" placeholder="https://..." />
                            <small class="text-muted">Hiển thị trên các card hàng chờ (hình vuông nhỏ).</small>
                        </div>
                        <div class="mb-3">
                            <label asp-for="CoverImageUrl" class="form-label fw-semibold"></label>
                            <input asp-for="CoverImageUrl" class="form-control" placeholder="https://..." />
                            <small class="text-muted">Ảnh bìa lớn ở trang chi tiết quán.</small>
                        </div>
                        <div class="form-check mb-4">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold">Đang hoạt động</label>
                        </div>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Lưu cài đặt</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
