@model QueueLink.ViewModels.MenuCategoryViewModel
@{
    ViewData["Title"] = "Thêm danh mục";
    Layout = "_Layout";
}

<div class="container py-4">
    <a asp-controller="Owner" asp-action="Menu" asp-route-venueId="@ViewBag.VenueId" class="btn btn-link text-decoration-none mb-3">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-folder-plus me-2"></i>Thêm danh mục món ăn</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-controller="Owner" asp-action="CategoryCreate" asp-route-venueId="@ViewBag.VenueId">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="VenueId" />
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control" placeholder="VD: Món nướng, Đồ uống..." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="SortOrder" class="form-label fw-semibold"></label>
                            <input asp-for="SortOrder" class="form-control" type="number" />
                        </div>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Lưu</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
