@model IEnumerable<QueueLink.Models.Table>
@{
    ViewData["Title"] = "Quản lý bàn — " + ViewBag.VenueName;
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-controller="Owner" asp-action="Dashboard" asp-route-venueId="@ViewBag.VenueId" class="btn btn-link text-decoration-none p-0 mb-2">
                <i class="bi bi-arrow-left"></i> Quay lại Dashboard
            </a>
            <h4 class="fw-bold mb-0"><i class="bi bi-table me-2 text-primary"></i>Quản lý bàn — @ViewBag.VenueName</h4>
        </div>
        <a asp-action="TableCreate" asp-route-venueId="@ViewBag.VenueId" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Thêm bàn
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="row g-3">
        @foreach (var t in Model)
        {
            <div class="col-md-3 col-sm-4">
                <div class="card @(t.IsActive ? "" : "opacity-50 border-secondary")">
                    <div class="card-body text-center py-3">
                        <div class="mb-2">
                            @if (t.Status == QueueLink.Models.TableStatus.Available)
                            {
                                <span class="badge bg-success fs-6">🟢 Trống</span>
                            }
                            else if (t.Status == QueueLink.Models.TableStatus.Reserved)
                            {
                                <span class="badge bg-warning text-dark fs-6">🟡 Đặt trước</span>
                            }
                            else if (t.Status == QueueLink.Models.TableStatus.Occupied)
                            {
                                <span class="badge bg-danger fs-6">🔴 Có khách</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary fs-6">🟤 Dọn dẹp</span>
                            }
                        </div>
                        <h5 class="card-title fw-bold mb-1">@t.Name</h5>
                        <div class="small text-muted mb-2">@t.Capacity người</div>
                        <div class="d-flex gap-1 justify-content-center">
                            <a asp-action="TableEdit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="TableDelete" asp-route-id="@t.Id" method="post"
                                  onsubmit="return confirm('Xóa bàn @t.Name?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
