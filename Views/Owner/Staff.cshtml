@model IEnumerable<QueueLink.ViewModels.StaffVenueAssignmentViewModel>
@{
    ViewData["Title"] = "Phân công nhân viên — " + ViewBag.VenueName;
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-controller="Owner" asp-action="Dashboard" asp-route-venueId="@ViewBag.VenueId" class="btn btn-link text-decoration-none p-0 mb-2">
                <i class="bi bi-arrow-left"></i> Quay lại Dashboard
            </a>
            <h4 class="fw-bold mb-0"><i class="bi bi-people me-2 text-primary"></i>Nhân viên — @ViewBag.VenueName</h4>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Nhân viên</th>
                                <th>Email</th>
                                <th>Trạng thái</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@s.FullName</td>
                                    <td class="text-muted small">@s.Email</td>
                                    <td>
                                        @if (s.IsAssigned)
                                        {
                                            <span class="badge bg-success">Đã phân công</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Chưa phân công</span>
                                        }
                                    </td>
                                    <td>
                                        @if (s.IsAssigned)
                                        {
                                            <form asp-controller="Owner" asp-action="UnassignStaff"
                                                  asp-route-assignmentId="@s.AssignmentId" asp-route-venueId="@ViewBag.VenueId"
                                                  method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Bỏ phân công @s.FullName?');">
                                                    <i class="bi bi-x-circle me-1"></i>Bỏ phân công
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-controller="Owner" asp-action="AssignStaff"
                                                  asp-route-venueId="@ViewBag.VenueId" asp-route-userId="@s.UserId"
                                                  method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                    <i class="bi bi-plus-circle me-1"></i>Phân công
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
