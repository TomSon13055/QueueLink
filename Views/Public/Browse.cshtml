@model IEnumerable<QueueLink.Controllers.PublicVenueCardViewModel>
@{
    ViewData["Title"] = "Danh sách quán";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold"><i class="bi bi-shop text-primary me-2"></i>Danh sách quán</h1>
        <p class="text-muted fs-5">Khám phá các quán đang hoạt động — bấm vào để xem chi tiết, đặt bàn hoặc lấy số</p>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
            <h5>Chưa có quán nào đang hoạt động</h5>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var v in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <a asp-controller="Public" asp-action="Index" asp-route-slug="@v.Slug"
                       class="text-decoration-none text-dark venue-card-link">
                        <div class="card h-100 shadow-sm venue-card">
                            @* ── COVER IMAGE ── *@
                            <div class="venue-browse-cover">
                                @if (!string.IsNullOrEmpty(v.CoverImageUrl))
                                {
                                    <img src="@v.CoverImageUrl" alt="@v.Name"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                    <div class="venue-cover-fallback" style="display:none;">
                                        <i class="bi bi-shop"></i>
                                    </div>
                                }
                                else
                                {
                                    <div class="venue-cover-fallback">
                                        <i class="bi bi-shop"></i>
                                    </div>
                                }

                                @* Status pill overlay (top-right of cover) *@
                                <div class="venue-browse-pill">
                                    @if (v.AvailableTableCount > 0)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i>Còn bàn
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-exclamation-circle me-1"></i>Hết bàn
                                        </span>
                                    }
                                </div>
                            </div>

                            @* ── BODY ── *@
                            <div class="card-body d-flex">
                                @* Logo overlapping cover edge *@
                                <div class="venue-browse-logo flex-shrink-0">
                                    @if (!string.IsNullOrEmpty(v.LogoUrl))
                                    {
                                        <img src="@v.LogoUrl" alt="@v.Name"
                                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                        <div class="venue-logo-fallback" style="display:none;">
                                            <i class="bi bi-shop"></i>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="venue-logo-fallback">
                                            <i class="bi bi-shop"></i>
                                        </div>
                                    }
                                </div>

                                <div class="flex-grow-1 min-width-0 ms-3">
                                    <h5 class="fw-bold mb-1 text-truncate" title="@v.Name">@v.Name</h5>
                                    <p class="small text-muted mb-1 text-truncate" title="@v.Address">
                                        <i class="bi bi-geo-alt me-1"></i>@v.Address
                                    </p>
                                    @if (!string.IsNullOrEmpty(v.Description))
                                    {
                                        <p class="small text-muted mb-2 text-truncate" title="@v.Description">@v.Description</p>
                                    }
                                    <div class="d-flex gap-3 small text-muted">
                                        <span><i class="bi bi-table me-1"></i>@v.AvailableTableCount/@v.TotalTableCount bàn</span>
                                        <span><i class="bi bi-list-ol me-1"></i>@v.OpenQueueCount hàng</span>
                                    </div>
                                </div>
                            </div>

                            <div class="card-footer bg-white border-0 pt-0">
                                <div class="d-flex justify-content-between align-items-center small text-muted">
                                    <span><i class="bi bi-clock me-1"></i>@v.OpenTime.ToString("HH:mm") – @v.CloseTime.ToString("HH:mm")</span>
                                    <span class="text-primary fw-semibold">Xem chi tiết <i class="bi bi-arrow-right"></i></span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>
