@model QueueLink.Controllers.PublicVenueViewModel
@{
    ViewData["Title"] = Model.Venue.Name;
    Layout = "_Layout";
}

<div class="container py-4">
    @* ── COVER IMAGE ── *@
    <div class="mb-3">
        @if (!string.IsNullOrEmpty(Model.Venue.CoverImageUrl))
        {
            <img src="@Model.Venue.CoverImageUrl" alt="@Model.Venue.Name" class="venue-cover"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
            <div class="venue-cover-fallback" style="display:none;">
                <i class="bi bi-shop"></i>
            </div>
        }
        else
        {
            <div class="venue-cover-fallback">
                <i class="bi bi-shop"></i>
            </div>
        }
    </div>

    @* ── HEADER ── *@
    <div class="text-center mb-4">
        <h2 class="fw-bold">🍲 @Model.Venue.Name</h2>
        <p class="text-muted mb-1">
            <i class="bi bi-geo-alt me-1"></i>@Model.Venue.Address
            @if (!string.IsNullOrEmpty(Model.Venue.Phone))
            {
                <span class="ms-3"><i class="bi bi-telephone me-1"></i>@Model.Venue.Phone</span>
            }
        </p>
        <p class="small text-muted">
            <i class="bi bi-clock me-1"></i>
            Mở cửa: @Model.Venue.OpenTime.ToString("HH:mm") – @Model.Venue.CloseTime.ToString("HH:mm")
        </p>
    </div>

    @* ── ACTION BUTTONS ── *@
    <div class="row justify-content-center mb-4">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex gap-3 flex-wrap justify-content-center">
                    <a asp-controller="Reservation" asp-action="Create" asp-route-slug="@Model.Venue.Slug"
                       class="btn btn-warning btn-lg px-4">
                        <i class="bi bi-calendar-plus me-2"></i>📅 Đặt trước bàn
                    </a>

                    @if (!Model.HasAvailableTables && Model.Queues.Any())
                    {
                        <a asp-controller="Public" asp-action="Queue" asp-route-slug="@Model.Venue.Slug"
                           class="btn btn-danger btn-lg px-4">
                            <i class="bi bi-ticket-perforated me-2"></i>🎫 Lấy số chờ
                        </a>
                    }
                </div>
                @if (Model.HasAvailableTables)
                {
                    <div class="card-footer bg-success text-white text-center py-2">
                        <i class="bi bi-check-circle me-1"></i>Còn bàn trống — hãy đặt trước để giữ chỗ!
                    </div>
                }
                else
                {
                    <div class="card-footer bg-danger text-white text-center py-2">
                        <i class="bi bi-exclamation-triangle me-1"></i>Tất cả bàn đang được sử dụng
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── TABLE STATUS — floor plan + legend ── *@
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h5 class="mb-0 fw-bold"><i class="bi bi-grid-3x3-gap me-2 text-primary"></i>Sơ đồ bàn</h5>
            <div class="small">
                <span class="me-3"><span class="legend-dot bg-success"></span>Trống</span>
                <span class="me-3"><span class="legend-dot bg-warning"></span>Đặt trước</span>
                <span class="me-3"><span class="legend-dot bg-danger"></span>Có khách</span>
                <span class="me-3"><span class="legend-dot bg-secondary"></span>Dọn dẹp</span>
            </div>
        </div>
        <div class="card-body">
            @{
                var tablesByBlock = Model.Tables
                    .GroupBy(t => string.IsNullOrWhiteSpace(t.Block) ? "Khu vực chính" : t.Block!)
                    .OrderBy(g => g.Key == "Khu vực chính" ? 0 : 1)
                    .ThenBy(g => g.Key)
                    .ToList();
            }
            @foreach (var block in tablesByBlock)
            {
                <div class="mb-4">
                    <h6 class="fw-bold text-uppercase text-muted small mb-2">
                        <i class="bi bi-bookmark-fill me-1"></i>@block.Key
                        <span class="badge bg-light text-dark ms-2">@block.Count() bàn</span>
                    </h6>
                    <div class="public-floor-canvas">
                        @foreach (var t in block)
                        {
                            var statusClass = t.Status switch
                            {
                                QueueLink.Models.TableStatus.Available => "table-status-available",
                                QueueLink.Models.TableStatus.Reserved => "table-status-reserved",
                                QueueLink.Models.TableStatus.Occupied => "table-status-occupied",
                                _ => "table-status-cleaning"
                            };
                            <div class="public-floor-table @statusClass"
                                 style="left:@(t.LayoutX.ToString(System.Globalization.CultureInfo.InvariantCulture))%;top:@(t.LayoutY.ToString(System.Globalization.CultureInfo.InvariantCulture))%;width:@(t.LayoutW.ToString(System.Globalization.CultureInfo.InvariantCulture))%;height:@(t.LayoutH.ToString(System.Globalization.CultureInfo.InvariantCulture))%;"
                                 title="@t.Name — @t.Capacity người">
                                <div class="floor-table-name">@t.Name</div>
                                <div class="floor-table-meta">@t.Capacity👤</div>
                                @if (t.Status == QueueLink.Models.TableStatus.Reserved && !string.IsNullOrEmpty(t.ReservationCustomer))
                                {
                                    <div class="floor-table-res">
                                        <i class="bi bi-calendar-check"></i> @t.ReservationTime?.ToString("HH:mm")
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    @* ── QUEUE INFO ── *@
    @if (Model.Queues.Any())
    {
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-list-ol me-2 text-info"></i>Hàng đợi</h5>
            </div>
            <div class="card-body">
                @foreach (var q in Model.Queues)
                {
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <div>
                            <div class="fw-semibold">@q.Name</div>
                            <div class="small text-muted">@q.WaitingCount người đang chờ</div>
                        </div>
                        @if (!Model.HasAvailableTables)
                        {
                            <a asp-controller="Public" asp-action="Queue" asp-route-slug="@Model.Venue.Slug"
                               class="btn btn-outline-danger btn-sm">
                                Lấy số
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>
