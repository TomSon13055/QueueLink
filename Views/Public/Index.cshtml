@model QueueLink.Controllers.PublicVenueViewModel
@{
    ViewData["Title"] = Model.Venue.Name;
    Layout = "_Layout";
}

<div class="container py-4">
    @* ── COVER IMAGE ── *@
    <div class="mb-3">
        @if (!string.IsNullOrEmpty(Model.Venue.CoverImageUrl))
        {
            <img src="@Model.Venue.CoverImageUrl" alt="@Model.Venue.Name" class="venue-cover"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
            <div class="venue-cover-fallback" style="display:none;">
                <i class="bi bi-shop"></i>
            </div>
        }
        else
        {
            <div class="venue-cover-fallback">
                <i class="bi bi-shop"></i>
            </div>
        }
    </div>

    @* ── HEADER ── *@
    <div class="text-center mb-4">
        <h2 class="fw-bold">🍲 @Model.Venue.Name</h2>
        <p class="text-muted mb-1">
            <i class="bi bi-geo-alt me-1"></i>@Model.Venue.Address
            @if (!string.IsNullOrEmpty(Model.Venue.Phone))
            {
                <span class="ms-3"><i class="bi bi-telephone me-1"></i>@Model.Venue.Phone</span>
            }
        </p>
        <p class="small text-muted">
            <i class="bi bi-clock me-1"></i>
            Mở cửa: @Model.Venue.OpenTime.ToString("HH:mm") – @Model.Venue.CloseTime.ToString("HH:mm")
        </p>
    </div>

    @* ── ACTION BUTTONS ── *@
    <div class="row justify-content-center mb-4">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex gap-3 flex-wrap justify-content-center">
                    <a asp-controller="Reservation" asp-action="Create" asp-route-slug="@Model.Venue.Slug"
                       class="btn btn-warning btn-lg px-4">
                        <i class="bi bi-calendar-plus me-2"></i>📅 Đặt trước bàn
                    </a>

                    @if (!Model.HasAvailableTables && Model.Queues.Any())
                    {
                        <a asp-controller="Public" asp-action="Queue" asp-route-slug="@Model.Venue.Slug"
                           class="btn btn-danger btn-lg px-4">
                            <i class="bi bi-ticket-perforated me-2"></i>🎫 Lấy số chờ
                        </a>
                    }
                </div>
                @if (Model.HasAvailableTables)
                {
                    <div class="card-footer bg-success text-white text-center py-2">
                        <i class="bi bi-check-circle me-1"></i>Còn bàn trống — hãy đặt trước để giữ chỗ!
                    </div>
                }
                else
                {
                    <div class="card-footer bg-danger text-white text-center py-2">
                        <i class="bi bi-exclamation-triangle me-1"></i>Tất cả bàn đang được sử dụng
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── TABLE STATUS ── *@
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-table me-2 text-primary"></i>Tình trạng bàn</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Bàn</th>
                            <th>Sức chứa</th>
                            <th>Tình trạng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.Tables)
                        {
                            <tr>
                                <td class="fw-semibold">@t.Name</td>
                                <td>@t.Capacity người</td>
                                <td>
                                    @if (t.Status == QueueLink.Models.TableStatus.Available)
                                    {
                                        <span class="badge bg-success">🟢 Trống</span>
                                    }
                                    else if (t.Status == QueueLink.Models.TableStatus.Reserved)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            🟡 Đặt trước
                                            @if (!string.IsNullOrEmpty(t.ReservationCustomer))
                                            {
                                                <span>— @t.ReservationCustomer (@t.ReservationTime?.ToString("HH:mm"))</span>
                                            }
                                        </span>
                                    }
                                    else if (t.Status == QueueLink.Models.TableStatus.Occupied)
                                    {
                                        <span class="badge bg-danger">🔴 Đang có khách</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">🟤 Đang dọn dẹp</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── QUEUE INFO ── *@
    @if (Model.Queues.Any())
    {
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-list-ol me-2 text-info"></i>Hàng đợi</h5>
            </div>
            <div class="card-body">
                @foreach (var q in Model.Queues)
                {
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <div>
                            <div class="fw-semibold">@q.Name</div>
                            <div class="small text-muted">@q.WaitingCount người đang chờ</div>
                        </div>
                        @if (!Model.HasAvailableTables)
                        {
                            <a asp-controller="Public" asp-action="Queue" asp-route-slug="@Model.Venue.Slug"
                               class="btn btn-outline-danger btn-sm">
                                Lấy số
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>
