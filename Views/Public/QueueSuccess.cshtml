@{
    var ticket = ViewBag.Ticket as QueueLink.Models.QueueTicket;
    var waitingAhead = ViewBag.WaitingAhead as int? ?? 0;
    var venueName = ViewBag.VenueName as string ?? "";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="text-center mb-4">
        <div class="text-success mb-3">
            <i class="bi bi-check-circle-fill" style="font-size: 4rem;"></i>
        </div>
        <h2 class="fw-bold text-success">Bạn đã lấy số thành công!</h2>
        <p class="text-muted">@venueName</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-primary">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h5 class="mb-0">SỐ THỨ TỰ CỦA BẠN</h5>
                </div>
                <div class="card-body text-center py-5">
                    <div class="display-1 fw-bold text-primary mb-3">@ticket?.TicketCode</div>
                    <div class="mb-2"><strong>@ticket?.CustomerName</strong></div>
                    <div class="text-muted small">
                        Lấy lúc: @ticket?.CreatedAt.ToString("HH:mm")
                    </div>
                </div>
            </div>

            @if (ticket?.Status == QueueLink.Models.TicketStatus.Waiting)
            {
                <div class="alert alert-warning text-center mt-3">
                    <div class="fw-bold">Bạn còn <span class="display-6">@waitingAhead</span> người trước bạn.</div>
                    <div class="small">Vui lòng đợi được gọi tên.</div>
                </div>
            }

            <div class="text-center mt-4">
                <a asp-action="Index" asp-route-slug="@ticket?.QueueService?.Venue?.Slug"
                   class="btn btn-outline-secondary me-2">
                    <i class="bi bi-house me-1"></i>Về trang chủ
                </a>
                <button class="btn btn-outline-primary" onclick="location.reload()">
                    <i class="bi bi-arrow-clockwise me-1"></i>Cập nhật
                </button>
            </div>
        </div>
    </div>
</div>
