@{
    var venue = ViewBag.Venue as QueueLink.Models.Venue;
    var queues = ViewBag.Queues as List<QueueLink.Models.QueueService>;
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="text-center mb-4">
        <h3 class="fw-bold text-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>Tất cả bàn đang được sử dụng
        </h3>
        <p class="text-muted">Lấy số để được xếp bàn ngay khi có chỗ trống.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-danger text-white text-center py-3">
                    <h5 class="mb-0"><i class="bi bi-ticket-perforated me-2"></i>Lấy số chờ</h5>
                    <div class="small mt-1">@(venue?.Name ?? "")</div>
                </div>
                <div class="card-body">
                    @if (queues != null && queues.Any())
                    {
                        <form asp-action="Queue" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="slug" value="@venue?.Slug" />

                            @foreach (var q in queues)
                            {
                                <input type="hidden" name="queueServiceId" value="@q.Id" />
                            }

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Họ tên</label>
                                <input type="text" name="customerName" class="form-control"
                                       placeholder="Nhập tên của bạn" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Số điện thoại</label>
                                <input type="tel" name="customerPhone" class="form-control"
                                       placeholder="0xxx xxx xxx" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Chọn hàng đợi</label>
                                @foreach (var q in queues!)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="queueServiceId"
                                               id="queue-@q.Id" value="@q.Id"
                                               @(q == queues.First() ? "checked" : "") />
                                        <label class="form-check-label" for="queue-@q.Id">
                                            <strong>@q.Name</strong>
                                            @if (!string.IsNullOrEmpty(q.Description))
                                            {
                                                <span class="text-muted small"> — @q.Description</span>
                                            }
                                        </label>
                                    </div>
                                }
                            </div>
                            <button type="submit" class="btn btn-danger w-100 btn-lg">
                                <i class="bi bi-ticket-perforated me-2"></i>Lấy số ngay
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            Hiện không có hàng đợi nào đang mở.
                        </div>
                    }
                </div>
            </div>

            <div class="text-center mt-4">
                <a asp-action="Index" asp-route-slug="@venue?.Slug" class="btn btn-outline-secondary">
                    <i class="bi bi-house me-1"></i>Về trang chủ
                </a>
            </div>
        </div>
    </div>
</div>
