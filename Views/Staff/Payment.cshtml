@model QueueLink.Models.Order
@{
    ViewData["Title"] = "Thanh toán — " + Model.Table?.Name;
    Layout = "_Layout";
}

<div class="container py-4">
    <a asp-controller="Staff" asp-action="FloorPlan" asp-route-venueId="@Model.VenueId" class="btn btn-link text-decoration-none mb-3">
        <i class="bi bi-arrow-left"></i> Quay lại sơ đồ bàn
    </a>

    @if (TempData["PayOSUrl"] != null)
    {
        <div class="alert alert-info">
            <i class="bi bi-link-45deg me-1"></i>
            Link thanh toán PayOS:
            <a href="@TempData["PayOSUrl"]" target="_blank" class="alert-link">@TempData["PayOSUrl"]</a>
            <br><small>Sau khi khách thanh toán, bấm xác nhận bên dưới.</small>
        </div>
    }

    <div class="row g-4">
        @* ── HÓA ĐƠN ── *@
        <div class="col-md-5">
            <div class="card shadow h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-receipt me-2"></i>Hóa đơn</h5>
                </div>
                <div class="card-body p-0">
                    <div class="p-3 bg-light border-bottom">
                        <div><strong>Bàn:</strong> @Model.Table?.Name</div>
                        <div><strong>Ngày:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                        @if (!string.IsNullOrEmpty(Model.OrderCode))
                        {
                            <div><strong>Mã đơn:</strong> @Model.OrderCode</div>
                        }
                    </div>
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Món</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        @item.ItemName
                                        @if (!string.IsNullOrEmpty(item.Notes))
                                        {
                                            <div class="small text-muted">@item.Notes</div>
                                        }
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@item.TotalPrice.ToString("N0")đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="p-3 border-top">
                        <div class="d-flex justify-content-between mb-1">
                            <span>Tạm tính</span>
                            <span>@Model.SubTotal.ToString("N0")đ</span>
                        </div>
                        @if (Model.DiscountAmount > 0)
                        {
                            <div class="d-flex justify-content-between mb-1 text-danger">
                                <span>Giảm giá</span>
                                <span>-@Model.DiscountAmount.ToString("N0")đ</span>
                            </div>
                        }
                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5">
                            <span>TỔNG CỘNG</span>
                            <span class="text-success">@Model.TotalAmount.ToString("N0")đ</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── THANH TOÁN ── *@
        <div class="col-md-7">
            <div class="card shadow h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-credit-card me-2"></i>Phương thức thanh toán</h5>
                </div>
                <div class="card-body">

                    @* Giảm giá *@
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Giảm giá (VND)</label>
                        <div class="input-group" style="max-width: 250px;">
                            <input type="number" id="discountInput" class="form-control"
                                   value="@Model.DiscountAmount" min="0" max="@Model.SubTotal" />
                            <button class="btn btn-outline-primary" onclick="applyDiscount()">Áp dụng</button>
                        </div>
                    </div>

                    <hr />

                    @* Tiền mặt *@
                    <div class="mb-4">
                        <h6 class="fw-bold mb-3"><i class="bi bi-cash-coin me-2 text-success"></i>Tiền mặt</h6>
                        <form asp-action="PayCash" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="orderId" value="@Model.Id" />
                            <div class="mb-2">
                                <label class="form-label">Số tiền khách đưa</label>
                                <input type="number" name="customerPaid" class="form-control"
                                       placeholder="Nhập số tiền..." min="0" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Ghi chú</label>
                                <input type="text" name="notes" class="form-control" placeholder="VD: Khách thanh toán đủ" />
                            </div>
                            <button type="submit" class="btn btn-success w-100">
                                <i class="bi bi-check-circle me-1"></i>Xác nhận tiền mặt (@Model.TotalAmount.ToString("N0")đ)
                            </button>
                        </form>
                    </div>

                    <hr />

                    @* PayOS *@
                    <div class="mb-3">
                        <h6 class="fw-bold mb-3"><i class="bi bi-qr-code me-2 text-primary"></i>PayOS (QR / ATM / Visa)</h6>
                        @if (TempData["PayOSUrl"] == null)
                        {
                            <form asp-action="PayPayOS" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="orderId" value="@Model.Id" />
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-qr-code me-1"></i>Tạo link thanh toán PayOS
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="alert alert-success">
                                <div class="mb-2">Đã tạo link thanh toán. Chờ khách quét QR...</div>
                                <form asp-action="ConfirmPayOSPayment" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="orderId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-success btn-sm">
                                        <i class="bi bi-check-circle me-1"></i>Xác nhận đã thanh toán PayOS
                                    </button>
                                </form>
                            </div>
                        }
                        <small class="text-muted d-block mt-1">
                            Tạo link QR PayOS cho khách thanh toán qua điện thoại.
                        </small>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between mt-3">
                        <a asp-action="OrderItems" asp-route-orderId="@Model.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Quay lại gọi món
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function applyDiscount() {
            var amount = parseInt(document.getElementById('discountInput').value) || 0;
            fetch('@Url.Action("ApplyDiscount", "Staff")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                },
                body: 'orderId=@Model.Id&discountAmount=' + amount
            }).then(r => { if (r.ok) location.reload(); });
        }
    </script>
}
