@model IEnumerable<QueueLink.Models.MenuCategory>
@{
    var order = ViewBag.Order as QueueLink.Models.Order;
    var search = ViewBag.Search as string ?? "";
    ViewData["Title"] = "Gọi món — " + order?.Table?.Name ?? "";
    Layout = "_Layout";
}

<div class="container-fluid py-3">
    @* Header *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <a asp-action="FloorPlan" asp-route-venueId="@order?.VenueId" class="btn btn-link text-decoration-none">
                <i class="bi bi-arrow-left"></i> Sơ đồ bàn
            </a>
            <h4 class="d-inline ms-2 mb-0">
                <i class="bi bi-list-ul me-2 text-primary"></i>Gọi món — @order?.Table?.Name
            </h4>
            @if (!string.IsNullOrEmpty(order?.OrderCode))
            {
                <span class="badge bg-primary ms-2">@order.OrderCode</span>
            }
        </div>
        <div class="text-end">
            <div class="fs-5 fw-bold text-success">@order?.TotalAmount.ToString("N0")đ</div>
            <span class="badge @(order?.Status == QueueLink.Models.OrderStatus.Submitted ? "bg-warning text-dark" : "bg-success")">
                @(order?.Status == QueueLink.Models.OrderStatus.Submitted ? "Đã gửi bếp" : "Mở")
            </span>
        </div>
    </div>

    @* Order items summary bar *@
    @if (order != null && order.Items.Any())
    {
        <div class="card mb-3 border-primary">
            <div class="card-body py-2 d-flex justify-content-between align-items-center">
                <div>
                    <span class="badge bg-primary me-2">@order.Items.Sum(i => i.Quantity) món</span>
                    @foreach (var item in order.Items.Take(5))
                    {
                        <span class="badge bg-light text-dark border me-1">@item.ItemName ×@item.Quantity</span>
                    }
                    @if (order.Items.Count > 5)
                    {
                        <span class="text-muted small">+@(order.Items.Count - 5) món khác</span>
                    }
                </div>
                <div class="d-flex gap-2">
                    @if (order.Status == QueueLink.Models.OrderStatus.Open)
                    {
                        <form asp-action="SubmitOrder" asp-route-orderId="@order.Id" method="post">
                            <input type="hidden" name="notes" id="orderNotes" value="" />
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-send me-1"></i>Gửi bếp
                            </button>
                        </form>
                        <a asp-action="Payment" asp-route-orderId="@order.Id" class="btn btn-success">
                            <i class="bi bi-currency-dollar me-1"></i>Thanh toán
                        </a>
                    }
                    else
                    {
                        <a asp-action="Payment" asp-route-orderId="@order.Id" class="btn btn-success">
                            <i class="bi bi-currency-dollar me-1"></i>Thanh toán
                        </a>
                    }
                </div>
            </div>
        </div>
    }

    @* Search bar *@
    <div class="row mb-3">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" id="menuSearch" class="form-control"
                       placeholder="Tìm món ăn..."
                       value="@search"
                       onkeydown="if(event.key==='Enter') { event.preventDefault(); searchMenu(); }" />
                <button class="btn btn-primary" onclick="searchMenu()">Tìm</button>
            </div>
            <div id="searchResults" class="mt-2"></div>
        </div>
    </div>

    <div class="row">
        @* Menu categories *@
        <div class="col-md-8">
            <div class="accordion" id="menuAccordion">
                @foreach (var cat in Model)
                {
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="heading-@cat.Id">
                            <button class="accordion-button @(cat == Model.First() ? "" : "collapsed")" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#cat-@cat.Id">
                                <strong>@cat.Name</strong>
                                <span class="badge bg-secondary ms-2">@cat.Items.Count()</span>
                            </button>
                        </h2>
                        <div id="cat-@cat.Id" class="accordion-collapse collapse @(cat == Model.First() ? "show" : "")"
                             data-bs-parent="#menuAccordion">
                            <div class="accordion-body p-0">
                                @if (!cat.Items.Any())
                                {
                                    <div class="text-center text-muted py-3">Chưa có món.</div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover mb-0">
                                            <tbody>
                                                @foreach (var item in cat.Items)
                                                {
                                                    <tr>
                                                        <td class="w-50">
                                                            <div class="fw-semibold">@item.Name</div>
                                                            @if (!string.IsNullOrEmpty(item.Description))
                                                            {
                                                                <div class="small text-muted">@item.Description</div>
                                                            }
                                                        </td>
                                                        <td class="text-end fw-bold text-success">
                                                            @item.Price.ToString("N0")đ
                                                        </td>
                                                        <td class="text-end" style="width: 120px;">
                                                            @if (item.Price > 0)
                                                            {
                                                                <div class="input-group input-group-sm">
                                                                    <input type="number" id="qty-@item.Id"
                                                                           class="form-control" value="1" min="1" style="width: 60px;" />
                                                                    <button class="btn btn-success" onclick="addItem(@item.Id, '@item.Name.Replace("'", "\\'")', @item.Price)">
                                                                        <i class="bi bi-plus-lg"></i>
                                                                    </button>
                                                                </div>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* Current order items *@
        <div class="col-md-4">
            <div class="card shadow-sm sticky-top" style="top: 20px;">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-receipt me-1"></i>Đơn hiện tại</h6>
                </div>
                <div class="card-body p-0" style="max-height: 60vh; overflow-y: auto;">
                    @if (order == null || !order.Items.Any())
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-receipt fs-1 d-block mb-2"></i>
                            Chưa có món nào.
                        </div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in order.Items)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center py-2">
                                    <div>
                                        <div class="small fw-semibold">@item.ItemName</div>
                                        @item.UnitPrice.ToString("N0")đ × @item.Quantity
                                    </div>
                                    <div class="text-end">
                                        <div class="fw-bold">@item.TotalPrice.ToString("N0")đ</div>
                                        <div class="btn-group btn-group-sm">
                                            @if (order.Status == QueueLink.Models.OrderStatus.Open)
                                            {
                                                <button class="btn btn-outline-secondary"
                                                        onclick="updateQty(@item.Id, @item.Quantity - 1)">
                                                    <i class="bi bi-dash"></i>
                                                </button>
                                                <button class="btn btn-outline-secondary"
                                                        onclick="updateQty(@item.Id, @item.Quantity + 1)">
                                                    <i class="bi bi-plus"></i>
                                                </button>
                                                <button class="btn btn-outline-danger"
                                                        onclick="removeItem(@item.Id)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
                @if (order != null && order.Items.Any())
                {
                    <div class="card-footer bg-white">
                        <div class="d-flex justify-content-between fw-bold fs-5">
                            <span>Tổng cộng</span>
                            <span class="text-success">@order.TotalAmount.ToString("N0")đ</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var orderId = @(order?.Id ?? 0);

        function addItem(menuItemId, name, price) {
            var qtyInput = document.getElementById('qty-' + menuItemId);
            var qty = qtyInput ? parseInt(qtyInput.value) || 1 : 1;
            fetch('@Url.Action("AddOrderItem", "Staff")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                },
                body: 'orderId=' + orderId + '&menuItemId=' + menuItemId + '&quantity=' + qty
            }).then(r => { if (r.ok) location.reload(); });
        }

        function updateQty(itemId, qty) {
            fetch('@Url.Action("UpdateOrderItemQuantity", "Staff")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                },
                body: 'itemId=' + itemId + '&quantity=' + qty
            }).then(r => { if (r.ok) location.reload(); });
        }

        function removeItem(itemId) {
            fetch('@Url.Action("RemoveOrderItem", "Staff")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                },
                body: 'itemId=' + itemId
            }).then(r => { if (r.ok) location.reload(); });
        }

        function searchMenu() {
            var q = document.getElementById('menuSearch').value;
            fetch('@Url.Action("SearchMenuItems", "Staff")?orderId=' + orderId + '&q=' + encodeURIComponent(q))
                .then(r => r.json())
                .then(items => {
                    var html = '';
                    if (items.length === 0) {
                        html = '<div class="text-muted small">Không tìm thấy món nào.</div>';
                    } else {
                        items.forEach(item => {
                            html += '<div class="d-flex justify-content-between align-items-center p-2 border rounded mb-1 bg-white">';
                            html += '<div><strong>' + item.name + '</strong><br><small class="text-muted">' + item.categoryName + '</small>';
                            html += ' — <strong class="text-success">' + item.price.toLocaleString() + 'đ</strong></div>';
                            html += '<button class="btn btn-sm btn-success" onclick="addItem(' + item.id + ', \'' + item.name.replace(/'/g, "\\'") + '\', ' + item.price + ')"><i class="bi bi-plus-lg"></i></button>';
                            html += '</div>';
                        });
                    }
                    document.getElementById('searchResults').innerHTML = html;
                });
        }
    </script>
}
